_worker.js

# Wrangler-Config
wrangler.jsonc
wrangler.toml

# Git-Internals (waren bisher fälschlicherweise als Asset hochgeladen)
.git/
.gitignore
.gitattributes

# Wrangler-Cache
.wrangler/

# macOS
.DS_Store
